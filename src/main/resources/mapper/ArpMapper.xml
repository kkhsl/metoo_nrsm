    <update id="writeArp">
        INSERT INTO metoo_arp_gather (
            addTime,
            v4ip,
            mac,
            PORT,
            v6ip,
            deviceIp,
            deviceName,
            macVendor
        ) SELECT
            arp.*, metoo_mac_vendor.vendor macVendor
        FROM
            (
                SELECT
                    *
                FROM
                    (
                        SELECT
                            metoo_ipv4.addTime,
                            metoo_ipv4.ip v4ip,
                            metoo_ipv4.mac,
                            metoo_ipv4. PORT,
                            NULL AS v6ip,
                            metoo_ipv4.deviceIp,
                            metoo_ipv4.deviceName
                        FROM
                            metoo_ipv4
                        WHERE
                            metoo_ipv4.id NOT IN (
                                SELECT DISTINCT
                                    metoo_ipv4.id
                                FROM
                                    metoo_ipv4
                                JOIN metoo_ipv6 ON metoo_ipv4.mac = metoo_ipv6.mac
                                AND metoo_ipv4. PORT = metoo_ipv6. PORT
                            )
                    ) arp2
                UNION
                    SELECT
                        addTime,
                        NULL AS ip,
                        mac,
                        PORT,
                        ip ipv6,
                        deviceIp,
                        deviceName
                    FROM
                        (
                            SELECT
                                *
                            FROM
                                metoo_ipv6
                            WHERE
                                metoo_ipv6.id NOT IN (
                                    SELECT DISTINCT
                                        metoo_ipv6.id
                                    FROM
                                        metoo_ipv4
                                    JOIN metoo_ipv6 ON metoo_ipv4.mac = metoo_ipv6.mac
                                    AND metoo_ipv4. PORT = metoo_ipv6. PORT
                                )
                        ) arp1
            ) arp
        LEFT JOIN metoo_mac_vendor ON metoo_mac_vendor.mac = substring(arp.mac, 1, 8);
    </update>

