    </resultMap>

    <select id="joinSelectObjAndIpv6" resultMap="joinSelectObjAndIpv6_Result">
          SELECT
            metoo_ipv4_mirror.id v4id,
            metoo_ipv4_mirror.ip v4ip,
            metoo_ipv4_mirror.mac,
            metoo_ipv4_mirror.port,
            metoo_ipv4_mirror.deviceIp,
            metoo_ipv4_mirror.deviceName,
            metoo_ipv6_mirror.id v6id,
            metoo_ipv6_mirror.ip v6ip,
            metoo_mac_vendor.vendor macVendor
        FROM
            metoo_ipv4_mirror
        JOIN metoo_ipv6_mirror ON metoo_ipv4_mirror.mac = metoo_ipv6_mirror.mac
        AND metoo_ipv4_mirror.port = metoo_ipv6_mirror.port
        LEFT JOIN metoo_mac_vendor ON metoo_mac_vendor.mac = substring(metoo_ipv4_mirror.mac, 1, 8);

    </select>

