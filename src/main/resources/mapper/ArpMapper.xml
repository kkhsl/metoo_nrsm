    <select id="selectObjByMap" parameterType="java.util.Map"
            resultType="com.metoo.nrsm.entity.nspm.Arp">
        SELECT *
        FROM metoo_arp
        <where>
            <if test="port != '' and port != null">
                AND port = #{port}
            </if>
            <if test="mac != '' and mac != null">
                AND mac = #{mac}
            </if>
            <if test="deviceIp != '' and deviceIp != null">
                AND deviceIp = #{deviceIp}
            </if>
        </where>
    </select>

