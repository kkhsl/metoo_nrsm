<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.metoo.nrsm.core.mapper.Ipv6Mapper">

    <insert id="save" parameterType="com.metoo.nrsm.entity.nspm.Ipv6">
        INSERT INTO metoo_ipv6
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="addTime != null">
                addTime,
            </if>
            <if test="ip != null and ip != ''">
                ip,
            </if>
            <if test="mac != null and mac != ''">
                mac,
            </if>
            <if test="port != null and port != ''">
                port,
            </if>
            <if test="deviceIp != null and deviceIp != ''">
                deviceIp,
            </if>
            <if test="deviceName != null and deviceName != ''">
                deviceName,
            </if>
        </trim>
        <trim prefix="VALUES(" suffix=")" suffixOverrides=",">
            <if test="addTime != null">
                #{addTime},
            </if>
            <if test="ip != null and ip != ''">
                #{ip},
            </if>
            <if test="mac != null and mac != ''">
                #{mac},
            </if>
            <if test="port != null and port != ''">
                #{port},
            </if>
            <if test="deviceIp != null and deviceIp != ''">
                #{deviceIp},
            </if>
            <if test="deviceName != null and deviceName != ''">
                #{deviceName},
            </if>
        </trim>
    </insert>


    <update id="removeDuplicates" statementType="CALLABLE">
        {call metoo_ipv6_remove_duplicates()}
    </update>


    <update id="truncateTable">
        TRUNCATE TABLE metoo_ipv6
    </update>

</mapper>